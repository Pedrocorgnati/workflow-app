# Workflow App - Environment Configuration Template
#
# INSTRUCOES:
# 1. Copie este arquivo para .env.local
# 2. Substitua os valores placeholder pelos valores reais
# 3. NUNCA commite .env com valores reais
# 4. Para obtener chaves API, veja as instrucoes abaixo

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SQLite database path (local development)
# Exemplo: /tmp/workflow.db ou ./data/workflow.db
# Para producao: use database gerenciada (Supabase, CloudSQL, etc)
DATABASE_URL=sqlite:///./workflow.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API KEYS & SECRETS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Anthropic Claude API
# Obter em: https://console.anthropic.com/account/keys
# Formato esperado: sk-ant-* (chave secreta comeca com prefixo sk-ant-)
CLAUDE_API_KEY=your-anthropic-api-key-here

# OpenAI API (ChatGPT, GPT-4, embeddings)
# Obter em: https://platform.openai.com/account/api-keys
# Formato esperado: sk-proj-* (projeto) ou sk-* (legacy)
OPENAI_API_KEY=your-openai-api-key-here

# Ollama - Local LLM (opcional, para modo offline)
# Formato: http://localhost:11434
# Se nao configurado, fallback para OpenAI
OLLAMA_API_URL=http://localhost:11434

# Venice API (fallback para AI)
# Obter em: https://venice.ai
# Formato esperado: chave tipo token
VENICE_API_KEY=your-venice-api-key-here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MONITORING & ERROR TRACKING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Sentry - Error tracking (opcional)
# Obter em: https://sentry.io
# Formato: https://{key}@{domain}.ingest.sentry.io/{project_id}
SENTRY_DSN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLICATION SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Ambiente: development | staging | production
# Controls logging level, error messages, and feature flags
ENVIRONMENT=development

# Debug mode (0 = false, 1 = true)
# Em producao SEMPRE debug=0
DEBUG=1

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Recomendacao: DEBUG (dev), WARNING (prod)
LOG_LEVEL=DEBUG

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUTHENTICATION & SECURITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT secret para assinar tokens de sessao
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANTE: Em producao, usar secrets manager
JWT_SECRET=your-jwt-secret-key-change-in-production

# Session timeout (minutos)
SESSION_TIMEOUT=30

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FEATURE FLAGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Remote Mode para sincronizacao com Android
REMOTE_MODE_ENABLED=1

# WebSocket server para Remote Mode
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=18765

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DEVELOPMENT TOOLS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Pydev remote debugger (para IDE como PyCharm)
# Ativar apenas em desenvolvimento
PYDEV_DEBUG_ENABLED=0
PYDEV_DEBUG_HOST=127.0.0.1
PYDEV_DEBUG_PORT=5678

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOCALIZATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Default language para UI (pt-BR, en-US, it-IT, etc)
DEFAULT_LANGUAGE=pt-BR

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CHECKLIST DE SEGURANCA ANTES DE PRODUCAO
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# ⚠️  OBRIGATORIOS ANTES DE DEPLOY:
#
# [ ] Todas as chaves API obtidas de consoles oficiais
# [ ] Nenhuma chave real presente em git (use .gitignore)
# [ ] JWT_SECRET alterado de default
# [ ] DEBUG=0 em producao
# [ ] DATABASE_URL aponta para database gerenciada
# [ ] Sentry configurado (opcional mas recomendado)
# [ ] Environment=production em producao
# [ ] LOG_LEVEL=WARNING em producao
# [ ] HTTPS habilitado para comunicacao de APIs
# [ ] .env.production seguro em secrets manager
# [ ] Revisar SECRETS-SCAN-REPORT.md para credenciais expostas
#
