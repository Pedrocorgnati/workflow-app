# ============================================================
# .env.docker.example — Variáveis para ambiente Docker
# ============================================================
# Copie para .env.docker e ajuste se necessário.
# Para a maioria dos casos, os defaults do docker-compose.yml já são suficientes.

# Qt — plataforma headless para testes sem display (não altere)
QT_QPA_PLATFORM=offscreen

# Python
PYTHONUNBUFFERED=1

# Banco de dados (vazio = usa sqlite em memória nos testes)
# Para usar arquivo em disco dentro do container:
# DB_PATH=/tmp/workflow-test.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
