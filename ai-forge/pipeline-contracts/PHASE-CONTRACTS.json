  "tripwires": [
    {
      "tripwire_id": "HT-RS-01",
      "scope": "loop-rocksmash:integrate",
      "command_under_test": "/loop-rocksmash:integrate",
      "subsystem": "rocksmash",
      "version_introduced": "1.7.0-pre",
      "status": "active",
      "description": "Idempotencia de `/loop-rocksmash:integrate`: rodar duas vezes na mesma task com hash identico do bloco de pareamento JSON detecta no-op e NAO duplica `## ADR Log` nem reescreve `## Task atual`. A 2a execucao deve sair com exit 4 (no-op) e o documento alvo (rocksmash architecture doc) deve permanecer byte-identico apos a 2a invocacao.",
      "dependencies": [
        "B5 (loop-rocksmash:integrate precisa existir)",
        "B3 (block hash JSON do pareamento)",
        "B10 (telemetria JSONL para registrar a deteccao de no-op)"
      ],
      "verification_script": "set -euo pipefail; TARGET_TASK=\"${TARGET_TASK:?defina TARGET_TASK=path/para/task.md}\"; TARGET_DOC=\"${TARGET_DOC:?defina TARGET_DOC=path/para/architecture.md}\"; sha_before=$(sha256sum \"$TARGET_DOC\" | awk '{print $1}'); /loop-rocksmash:integrate --task \"$TARGET_TASK\" >/dev/null 2>&1; rc1=$?; if [ \"$rc1\" -ne 0 ] && [ \"$rc1\" -ne 4 ]; then echo \"HT-RS-01 FAIL: 1a execucao retornou $rc1 (esperado 0 ou 4)\" >&2; exit 1; fi; sha_mid=$(sha256sum \"$TARGET_DOC\" | awk '{print $1}'); /loop-rocksmash:integrate --task \"$TARGET_TASK\" >/dev/null 2>&1; rc2=$?; sha_after=$(sha256sum \"$TARGET_DOC\" | awk '{print $1}'); if [ \"$rc2\" -ne 4 ]; then echo \"HT-RS-01 FAIL: 2a execucao retornou $rc2 (esperado 4 = no-op)\" >&2; exit 1; fi; if [ \"$sha_mid\" != \"$sha_after\" ]; then echo \"HT-RS-01 FAIL: doc mudou entre 1a e 2a execucao identicas ($sha_mid -> $sha_after)\" >&2; exit 1; fi; grep -c '^## ADR Log' \"$TARGET_DOC\" | awk '$1!=1 {print \"HT-RS-01 FAIL: ## ADR Log apareceu \"$1\" vezes (esperado 1)\" > \"/dev/stderr\"; exit 1}'; echo \"HT-RS-01 PASS: idempotencia preservada (rc1=$rc1, rc2=$rc2, hash estavel, ADR Log unico)\"; exit 0",
      "expected_exit_code": 4,
      "exit_codes_acceptable_first_run": [0, 4],
      "exit_code_required_second_run": 4,
      "on_fail": "abort with exit 1 — duplicacao de `## ADR Log` ou reescrita de `## Task atual` em re-execucao identica viola contrato de idempotencia documentado em source.md linha 448-451 do loop 05-19-tasks-faltantes",
      "secondary_conditions_runtime_warnings": [
        "lock_pid orfao no cursor (proxima execucao limpa automaticamente; NAO bloqueia HT-RS-01)",
        "hash mismatch entre `<!-- arch-seed:hash=... -->` e inputs atuais sem flag `--reseed` (regenera silenciosamente; NAO bloqueia HT-RS-01)",
        "backfill conflict (legacy doc com `## Arquitetura semeada` divergente; aborta com exit 8 e exige `--force-backfill`; NAO eh HT-RS-01)"
      ],
      "warnings_telemetry": {
        "stderr_format": "[WARN][rocksmash] <message>",
        "jsonl_path": "{wbs_root}/.rocksmash-telemetry/{YYYY-MM}.jsonl",
        "jsonl_schema_extension": "schema do B10 estendido com `level: 'info'|'warning'` e `message: <string>` opcionais (default level=info)",
        "workflow_app_capture": "stderr capturado no console widget do canto inferior do workflow-app (operador GUI ve sem precisar do terminal)",
        "toast_policy": "NAO criar toast amarelo — mantem decisao 'toast strict' verde+vermelho de source.md linha 166"
      },
      "introduced_by": "B11 do loop 05-19-tasks-faltantes (commit pendente)",
      "consumed_by": [
        "/dcp:directive-injector (smoke test pre-commit valida sem regressao)",
        "/loop-rocksmash:integrate (auto-aplicacao da regra interna)"
      ]
    }
  ],
  "canonical_loop": {
    "A": {
      "name": "Creation",
      "task_budget_tokens_default": 60000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 100000
    },
    "A.2": {
      "name": "Criacao de TDD",
      "condition": "modules.*.tdd.required == true",
      "gates": [
        "/tdd:test-plan",
        "/tdd:contract-from-openapi",
        "/tdd:behavior-from-specs",
        "/tdd:unit-skeletons",
        "/tdd:create-suite",
        "/tdd:lock"
      ],
      "state_transition": "creation -> execution (via /tdd:lock)",
      "enforces_invariant": "I-13",
      "task_budget_tokens_default": 140000,
      "task_budget_tokens_min": 60000,
      "task_budget_tokens_max": 220000
    },
    "B": {
      "name": "Execution",
      "task_budget_tokens_default": 120000,
      "task_budget_tokens_min": 40000,
      "task_budget_tokens_max": 200000,
      "entry_paths": [
        "creation -> execution (via /tdd:lock when modules.*.tdd.required == true)",
        "creation -> execution (via /execute-task lazy T02 when modules.*.tdd.required != true) — fires on first persist_files_touched call after task execution; owner is execute-task; preserves R01 (no attempt mutation), I-04 (no skipped states) and I-05 (timestamps)"
      ],
      "tdd_gate": {
        "enabled_when": "modules.*.tdd.required == true",
        "pre_implementation": "/execute-task PRE-0.5 asserts RED",
        "post_implementation": "/build-verify --tdd-gate asserts GREEN + LOCK intact",
        "enforces_invariant": "I-13"
      }
    },
    "C": {
      "name": "Linkage",
      "task_budget_tokens_default": 40000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 60000,
      "security_gate": {
        "enabled_when": "modules.*.criticality in ['high','critical'] OR modules.*.qa.security_review_required == true",
        "pre_linkage": "/skill:security-review-gate --module",
        "post_linkage": "/scope-drift-detect --module",
        "enforces_invariant": "I-18",
        "blocking_if_failed": true
      }
    },
    "D": {
      "name": "F8 micro",
      "task_budget_tokens_default": 80000,
      "task_budget_tokens_min": 30000,
      "task_budget_tokens_max": 120000
    },
    "D.5": {
      "name": "Review executed",
      "task_budget_tokens_default": 50000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 80000
    },
    "E": {
      "name": "QA micro",
      "task_budget_tokens_default": 60000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 100000
    },
    "F": {
      "name": "Stack plan",
      "task_budget_tokens_default": 40000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 60000
    },
    "F.2": {
      "name": "Stack check",
      "task_budget_tokens_default": 30000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 50000
    },
    "G": {
      "name": "Deploy partial",
      "task_budget_tokens_default": 30000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 50000
    },
    "H": {
      "name": "Commit",
      "task_budget_tokens_default": 20000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 30000
    },
    "I": {
      "name": "Human analysis",
      "task_budget_tokens_default": 40000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 60000
    }
  },
