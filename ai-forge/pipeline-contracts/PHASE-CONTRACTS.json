  "dcp_triggers": [
    {
      "id": "post-build-validate",
      "after": "/build-module-pipeline",
      "run": ["/delivery:validate"],
      "max_per_session": 3,
      "scope": "module"
    },
    {
      "id": "post-commit-record",
      "after": "/commit:*",
      "run": ["/memory:record-run", "/pipeline:collect-lessons"],
      "max_per_session": 5,
      "conditional": "module.state in ['done'] && last_transition_to == 'done'"
    },
    {
      "id": "validation-summary-qa-done",
      "after": "/validation-summary --module",
      "run": [],
      "conditional": "result == 'APROVADO' && module.deploy.target == 'none'",
      "notes": "autoriza workflow-app a acionar /commit:* que transiciona qa->done"
    },
    {
      "id": "validation-summary-qa-deploy",
      "after": "/validation-summary --module",
      "run": [],
      "conditional": "result == 'APROVADO' && module.deploy.target != 'none'",
      "notes": "autoriza workflow-app a acionar deploy e depois /post-deploy-verify"
    },
    {
      "id": "post-deploy-verify-ok",
      "after": "/post-deploy-verify",
      "run": [],
      "conditional": "result == 'OK'",
      "notes": "autoriza workflow-app a acionar /commit:* que transiciona deploy->done"
    },
    {
      "id": "post-unblock-validate",
      "after": "/delivery:unblock",
      "run": ["/delivery:validate"],
      "max_per_session": 10
    },
    {
      "id": "post-reopen-validate",
      "after": "/delivery:reopen",
      "run": ["/delivery:validate"],
      "max_per_session": 10
    }
  ]
