{
  "version": "1.4.1",
  "updated_at": "2026-04-24",
  "canonical_loop": {
    "A": {
      "name": "Creation",
      "task_budget_tokens_default": 60000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 100000
    },
    "A.2": {
      "name": "Criacao de TDD",
      "condition": "modules.*.tdd.required == true",
      "gates": [
        "/tdd:test-plan",
        "/tdd:contract-from-openapi",
        "/tdd:behavior-from-specs",
        "/tdd:unit-skeletons",
        "/tdd:create-suite",
        "/tdd:lock"
      ],
      "state_transition": "creation -> execution (via /tdd:lock)",
      "enforces_invariant": "I-13",
      "task_budget_tokens_default": 140000,
      "task_budget_tokens_min": 60000,
      "task_budget_tokens_max": 220000
    },
    "B": {
      "name": "Execution",
      "task_budget_tokens_default": 120000,
      "task_budget_tokens_min": 40000,
      "task_budget_tokens_max": 200000,
      "tdd_gate": {
        "enabled_when": "modules.*.tdd.required == true",
        "pre_implementation": "/execute-task PRE-0.5 asserts RED",
        "post_implementation": "/build-verify --tdd-gate asserts GREEN + LOCK intact",
        "enforces_invariant": "I-13"
      }
    },
    "C": {
      "name": "Linkage",
      "task_budget_tokens_default": 40000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 60000
    },
    "D": {
      "name": "F8 micro",
      "task_budget_tokens_default": 80000,
      "task_budget_tokens_min": 30000,
      "task_budget_tokens_max": 120000
    },
    "D.5": {
      "name": "Review executed",
      "task_budget_tokens_default": 50000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 80000
    },
    "E": {
      "name": "QA micro",
      "task_budget_tokens_default": 60000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 100000
    },
    "F": {
      "name": "Stack plan",
      "task_budget_tokens_default": 40000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 60000
    },
    "F.2": {
      "name": "Stack check",
      "task_budget_tokens_default": 30000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 50000
    },
    "G": {
      "name": "Deploy partial",
      "task_budget_tokens_default": 30000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 50000
    },
    "H": {
      "name": "Commit",
      "task_budget_tokens_default": 20000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 30000
    },
    "I": {
      "name": "Human analysis",
      "task_budget_tokens_default": 40000,
      "task_budget_tokens_min": 20000,
      "task_budget_tokens_max": 60000
    }
  },
  "phases": {
    "pre_f7_gate": {
      "required_commands": [
        "/intake-conformity-check",
        "/validate-pipeline"
      ],
      "blocking_if_missing": true
    },
    "f7_execution": {
      "required_when_present": {
        "triggers": ["/execute-task", "/auto-flow execute", "/front-end-build", "/back-end-build"],
        "required_commands": ["/front-end-review", "/gate:frontend-runtime", "/build-verify"]
      },
      "order_constraints": [
        {
          "before": "/front-end-review",
          "after": "/gate:frontend-runtime",
          "severity": "error"
        },
        {
          "before": "/gate:frontend-runtime",
          "after": "/build-verify",
          "severity": "error"
        }
      ]
    },
    "f9_intake_review": {
      "required_when_present": {
        "triggers": ["/intake-review:compare", "/intake-review:create-gaplist"],
        "required_commands": [
          "/intake-review:create-checklist",
          "/intake-review:list-improove",
          "/intake-review:compare"
        ]
      },
      "order_constraints": [
        {
          "before": "/intake-review:create-checklist",
          "after": "/intake-review:list-improove",
          "severity": "error"
        },
        {
          "before": "/intake-review:list-improove",
          "after": "/intake-review:compare",
          "severity": "error"
        },
        {
          "before": "/intake-review:compare",
          "after": "/intake-review:create-gaplist",
          "severity": "error"
        },
        {
          "before": "/intake-review:create-gaplist",
          "after": "/intake-review:execute-gaplist-p0",
          "severity": "error"
        },
        {
          "before": "/intake-review:execute-gaplist-p0",
          "after": "/intake-review:execute-gaplist-p1",
          "severity": "warning"
        },
        {
          "before": "/intake-review:execute-gaplist-p1",
          "after": "/intake-review:execute-gaplist-p2",
          "severity": "warning"
        },
        {
          "before": "/intake-review:execute-gaplist-p2",
          "after": "/intake-review:review-executed",
          "severity": "warning"
        }
      ],
      "blocking_if_missing": false
    },
    "f9_qa": {
      "required_when_present": {
        "triggers": ["/qa:prep", "/qa:trace", "/qa:report"],
        "required_commands": ["/brief-vs-frontend-review"]
      },
      "blocking_if_missing": false
    },
    "f8b_delivery": {
      "required_when_present": {
        "triggers": ["/delivery:identify-task", "/delivery:create-tasks", "/delivery:qa-gate", "/delivery:mcp-review", "/delivery:sign-off"],
        "required_commands": ["/delivery:analyse"]
      },
      "order_constraints": [
        {
          "before": "/delivery:analyse",
          "after": "/delivery:identify-task",
          "severity": "error"
        },
        {
          "before": "/delivery:identify-task",
          "after": "/delivery:create-tasks",
          "severity": "warning"
        },
        {
          "before": "/delivery:qa-gate",
          "after": "/delivery:mcp-review",
          "severity": "error"
        },
        {
          "before": "/delivery:mcp-review",
          "after": "/delivery:sign-off",
          "severity": "error"
        },
        {
          "before": "/delivery:sign-off",
          "after": "/delivery:pending-actions",
          "severity": "warning"
        }
      ],
      "blocking_if_missing": false
    }
  },
  "phase_triggers": {
    "f2_post_review_prd_flow": {
      "on_command_success": "/review-prd-flow",
      "auto_actions": [
        "/pipeline:run-scorecard --phase f2",
        "/pipeline:collect-lessons --phase f2",
        "/cmd:backlog-from-lessons --phase f2"
      ],
      "blocking": false,
      "cooldown_runs": 1
    },
    "f5_post_validate_pipeline": {
      "on_command_success": "/validate-pipeline",
      "auto_actions": [
        "/pipeline:run-scorecard --phase f5",
        "/pipeline:collect-lessons --phase f5",
        "/cmd:backlog-from-lessons --phase f5"
      ],
      "blocking": false,
      "cooldown_runs": 1
    },
    "f7_post_build_verify": {
      "on_command_success": "/build-verify",
      "auto_actions": [
        "/pipeline:run-scorecard --phase f7",
        "/pipeline:collect-lessons --phase f7",
        "/cmd:backlog-from-lessons --phase f7"
      ],
      "blocking": false,
      "cooldown_runs": 1
    },
    "f9_post_brief_vs_frontend_review": {
      "on_command_success": "/brief-vs-frontend-review",
      "auto_actions": [
        "/pipeline:run-scorecard --phase f9",
        "/pipeline:collect-lessons --phase f9",
        "/cmd:backlog-from-lessons --phase f9"
      ],
      "blocking": false,
      "cooldown_runs": 1
    },
    "f11_post_deploy_verify": {
      "on_command_success": "/post-deploy-verify",
      "auto_actions": [
        "/pipeline:run-scorecard --phase f11",
        "/pipeline:collect-lessons --phase f11",
        "/cmd:backlog-from-lessons --phase f11"
      ],
      "blocking": false,
      "cooldown_runs": 1
    },
    "f8b_post_sign_off": {
      "on_command_success": "/delivery:sign-off",
      "auto_actions": [
        "/pipeline:run-scorecard --phase f8b",
        "/pipeline:collect-lessons --phase f8b"
      ],
      "blocking": false,
      "cooldown_runs": 1
    }
  },
  "dcp_triggers": [
    {
      "id": "post-build-validate",
      "after": "/build-module-pipeline",
      "run": ["/delivery:validate"],
      "max_per_session": 3,
      "scope": "module"
    },
    {
      "id": "post-commit-record",
      "after": "/commit:*",
      "run": ["/memory:record-run", "/pipeline:collect-lessons"],
      "max_per_session": 5,
      "conditional": "module.state in ['done'] && last_transition_to == 'done'"
    },
    {
      "id": "validation-summary-qa-done",
      "after": "/validation-summary --module",
      "run": [],
      "conditional": "result == 'APROVADO' && module.deploy.target == 'none'",
      "notes": "autoriza workflow-app a acionar /commit:* que transiciona qa->done"
    },
    {
      "id": "validation-summary-qa-deploy",
      "after": "/validation-summary --module",
      "run": [],
      "conditional": "result == 'APROVADO' && module.deploy.target != 'none'",
      "notes": "autoriza workflow-app a acionar deploy e depois /post-deploy-verify"
    },
    {
      "id": "post-deploy-verify-ok",
      "after": "/post-deploy-verify",
      "run": [],
      "conditional": "result == 'OK'",
      "notes": "autoriza workflow-app a acionar /commit:* que transiciona deploy->done"
    },
    {
      "id": "post-unblock-validate",
      "after": "/delivery:unblock",
      "run": ["/delivery:validate"],
      "max_per_session": 10
    },
    {
      "id": "post-reopen-validate",
      "after": "/delivery:reopen",
      "run": ["/delivery:validate"],
      "max_per_session": 10
    }
  ]
}
