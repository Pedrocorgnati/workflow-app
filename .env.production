# ============================================
# WORKFLOW APP - VARIAVEIS DE AMBIENTE (PRODUCTION)
# ============================================
# Gerado por: /env-creation
# Data: 2026-03-15
# Stack: PySide6 (Frontend) + Python (Backend) + SQLite
#
# ⚠️ PRODUCAO - Use secrets manager (Vault, AWS Secrets Manager, etc.)
# ⚠️ NUNCA commite este arquivo com valores reais
# ============================================

# ────────────────────────────────────────────
# AMBIENTE E APLICACAO
# ────────────────────────────────────────────

# Ambiente de execucao
PYTHON_ENV=production

# Output sem buffer
PYTHONUNBUFFERED=1

# ────────────────────────────────────────────
# BANCO DE DADOS (PRODUCTION)
# ────────────────────────────────────────────

# SQLite - Banco de dados local (para production com desktop)
# ATENCAO: Para producao, considere migrar para PostgreSQL ou MySQL
# Se usar SQLite, ajuste o caminho para um local persistente
# Exemplo (Docker): /var/lib/workflow-app/workflow.db
DATABASE_URL=[PRODUCTION] use-secrets-manager-ou-docker-volume

# SQLite WAL Mode
DATABASE_WAL_MODE=1

# DB Path (production)
# [PRODUCTION] Configure path persistente (nao /tmp)
# DB_PATH=/var/lib/workflow-app/workflow.db

# ────────────────────────────────────────────
# INTEGRACAO COM CLAUDE CODE CLI (PRODUCTION)
# ────────────────────────────────────────────

# Workspace do Claude Code
# [PRODUCTION] Ajuste conforme ambiente de deploy
CLAUDE_CODE_WORKSPACE=/home/workflow-app/projects

# Permission Mode do Claude Code
# [PRODUCTION] Use bypassPermissions apenas com restricoes de acesso
CLAUDE_PERMISSION_MODE=acceptEdits

# ────────────────────────────────────────────
# DESENVOLVIMENTO E DEBUG (PRODUCTION)
# ────────────────────────────────────────────

# Log Level
# [PRODUCTION] Use WARNING ou ERROR para reducao de volume de logs
LOG_LEVEL=WARNING

# Modo Debug
# [PRODUCTION] SEMPRE desabilitar em producao
DEBUG=0

# ────────────────────────────────────────────
# SENTRY - ERROR TRACKING (PRODUCTION)
# ────────────────────────────────────────────

# [PRODUCTION] OBRIGATORIO configurar para rastreamento de erros em producao
# DSN obtido em: Sentry > Settings > Projects > workflow-app > Client Keys (DSN)
# Para obter sua propria chave:
#   1. Crie conta em https://sentry.io (plano pago para producao)
#   2. Va em Projects > Create Project > Python
#   3. Copie o DSN (URL com chave)
# Custo: Plano Starter $29/mes (50K eventos)
SENTRY_DSN=[PRODUCTION] use-secrets-manager

# Versao do app
# [PRODUCTION] Atualize com cada release (e.g., 1.0.0, 1.1.0)
APP_VERSION=[PRODUCTION] use-release-version

# ────────────────────────────────────────────
# INTEGRACAO COM AI/LLM (PRODUCTION)
# ────────────────────────────────────────────

# Claude API (Anthropic)
# [PRODUCTION] Use secrets manager
# Para obter sua propria chave:
#   1. Acesse https://console.anthropic.com
#   2. Va em API Keys > Create Key
#   3. Use secrets manager para armazenar
CLAUDE_API_KEY=[PRODUCTION] use-secrets-manager

# OpenAI API Key
# [PRODUCTION] Use secrets manager
# Para obter sua propria chave:
#   1. Crie conta em https://platform.openai.com/
#   2. Va em API Keys > Create new secret key
#   3. Use secrets manager para armazenar
OPENAI_API_KEY=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────
# OBSERVACOES PARA PRODUCTION
# ────────────────────────────────────────────
#
# 1. BANCO DE DADOS
#    Se usar SQLite: garanta backup periodico (cron job)
#    Se migrar para PostgreSQL: use RDS ou servico gerenciado
#
# 2. LOGGING
#    Configure centralizacao de logs (CloudWatch, DataDog, Splunk)
#    Configure rotacao de logs para evitar disco cheio
#
# 3. MONITORAMENTO
#    Configure alertas no Sentry para erros criticos
#    Configure uptime monitoring (Pingdom, UptimeRobot)
#    Configure alertas de CPU/memoria
#
# 4. SEGURANCA
#    Use secrets manager para todas as credenciais (AWS Secrets, Vault)
#    Nao commite este arquivo com valores reais
#    Use CI/CD (GitHub Actions) para injecao segura de secrets
#    Habilite 2FA em todas as contas de API
#
# 5. PERFORMANCE
#    Monitore latencia de banco de dados
#    Configure caching se necessario (Redis)
#    Configure connection pooling para SQLite
